<% const filterConfig = {
    dateInputs: typeof dateInputs !== 'undefined' ? dateInputs : [
        {
            id: 'startDateInput',
            name: 'startDate',
            type: 'date',
            label: 'Fecha de inicio:',
            col: '6'
        },
        {
            id: 'endDateInput',
            name: 'endDate',
            type: 'date',
            label: 'Fecha de fin:',
            col: '6'
        }
    ],
    selectInputs: typeof selectInputs !== 'undefined' ? selectInputs : []
} %>

<details class="table-filters-panel" open>
    <summary class="table-filters-summary" aria-label="Mostrar u ocultar filtros de tabla">
        <span class="table-filters-summary-title">
            <i class="fas fa-filter" aria-hidden="true"></i>
            Filtros
        </span>
        <span class="table-filters-summary-hint">Mostrar / ocultar</span>
    </summary>

    <div class="table-filters-content" aria-label="Filtros de tabla">
        <% if (filterConfig.selectInputs.length) { %>
        <div class="row table-filters">
            <% filterConfig.selectInputs.forEach(filter => { %>
                <%- include('./tableSelectFilter', {
                    id: filter.id,
                    label: filter.label,
                    col: filter.col
                }) %>
            <% }) %>
        </div>
    <% } %>

    <div class="row table-filters">
        <%- include('./outlineInputList', { inputs: filterConfig.dateInputs }) %>
    </div>

        <div class="table-filters-actions">
            <%- include('./button', {
                button : {
                    id: 'clearFiltersButton',
                    class: 'btn table-filter-button',
                    content: 'Limpiar filtros'
                }
            }) %>
        </div>
    </div>
</details>
