<% const filterConfig = {
    dateInputs: typeof dateInputs !== 'undefined' ? dateInputs : [
        {
            id: 'startDateInput',
            name: 'startDate',
            type: 'date',
            label: 'Fecha de inicio:',
            col: '6'
        },
        {
            id: 'endDateInput',
            name: 'endDate',
            type: 'date',
            label: 'Fecha de fin:',
            col: '6'
        }
    ],
    selectInputs: typeof selectInputs !== 'undefined' ? selectInputs : []
} %>

<div class="table-filters-panel" aria-label="Filtros de tabla">
    <% if (filterConfig.selectInputs.length) { %>
        <div class="row table-filters">
            <% filterConfig.selectInputs.forEach(filter => { %>
                <%- include('./tableSelectFilter', {
                    id: filter.id,
                    label: filter.label,
                    col: filter.col
                }) %>
            <% }) %>
        </div>
    <% } %>

    <div class="row table-filters">
        <%- include('./outlineInputList', { inputs: filterConfig.dateInputs }) %>
    </div>

    <div class="table-filters-actions">
        <%- include('./button', {
            button : {
                id: 'clearFiltersButton',
                class: 'btn table-filter-button',
                content: 'Limpiar filtros'
            }
        }) %>
    </div>
</div>
