<%
const buttonAttrs = button.attrs || {};
%>

<button id="<%= button.id %>" type="<%= button.type || 'button' %>" data-mdb-ripple-init class="<%= button.class %>"
    <% for (let key in buttonAttrs) { %>
        <%= key %>="<%= buttonAttrs[key] %>"
    <% } %>
>
    <%- button.content %>
</button>
