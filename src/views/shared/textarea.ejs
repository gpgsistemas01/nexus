<div class="form-outline" data-mdb-input-init>
    <textarea id="<%= input.id %>" name="<%= input.name %>" rows="4" class="form-control" 
        maxlength="500" aria-describedby="<%= `${ input.id }Error` %>"
    ></textarea>

    <%- include('./labelInput', { 
        id: input.id, 
        content: input.label 
    }) %>

    <%- include('./validationMessage', { 
        name: input.name, 
        errorClass: input.errorClass || 'invalid-feedback' 
    }) %>
</div>