<%
const getFilterColumnClass = col => {
    const tokens = String(col || '12').trim().split(/\s+/).filter(Boolean);
    const hasBaseColumn = tokens.some(token => token === 'col' || /^col(-\d+)?$/.test(token));
    const normalizedTokens = [];

    if (!hasBaseColumn) {
        normalizedTokens.push('col-12');
    }

    tokens.forEach(token => {
        if (token.startsWith('col-')) {
            normalizedTokens.push(token);
            return;
        }

        if (/^(sm|md|lg|xl|xxl)-\d+$/.test(token)) {
            normalizedTokens.push(`col-${token}`);
            return;
        }

        if (/^\d+$/.test(token)) {
            normalizedTokens.push(`col-md-${token}`);
            return;
        }

        normalizedTokens.push(token);
    });

    return [...new Set(normalizedTokens)].join(' ');
};
%>

<div class="mb-3 <%= getFilterColumnClass(col) %>">
    <label for="<%= id %>" class="form-label"><%= label %></label>

    <select id="<%= id %>" class="form-select w-100">
        <option></option>
    </select>
</div>
