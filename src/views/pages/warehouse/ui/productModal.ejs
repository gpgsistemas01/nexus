            groups: [
                {
                    type: 'inputs',
                    items: [
                        {
                            id: 'nameInput',
                            type: 'text',
                            name: 'name',
                            label: 'Nombre',
                            col: '6'
                        }
                    ]
                },
                {
                    type: 'selects',
                    items: [
                        {
                            id: 'productSupplierInput',
                            name: 'supplierId',
                            class: 'supplier-select',
                            col: 'col-6'
                        },
                        {
                            id: 'presentationInput',
                            name: 'presentationId',
                            class: 'presentation-select',
                            col: 'col-6'
                        },
                        {
                            id: 'unitMeasureInput',
                            name: 'unitMeasureId',
                            class: 'unit-measure-select',
                            col: 'col-6'
                        }
                    ]
                },
                {
                    type: 'inputs',
                    items: [
                        {
                            id: 'minStockInput',
                            type: 'number',
