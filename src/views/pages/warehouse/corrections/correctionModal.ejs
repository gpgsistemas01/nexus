<% const renderTotalsSummaryItem = ({ label, valueId, value }) => `
    <div class="col-12 col-md-4">
        <div class="border rounded p-3 h-100 bg-light">
            <span class="d-block small text-muted mb-1">${label}</span>
            <span id="${valueId}" class="fw-semibold">${value}</span>
        </div>
    </div>
`;
const form = {
    id: 'goodsReceiptCorrectionForm',
    notice: {
        class: 'alert alert-warning mb-0',
        content: 'Corrige el detalle seleccionado. La cantidad ajusta inventario automáticamente y los cambios de cantidad o costo pueden actualizar el total de la compra al guardar.'
    },
    sections: [
        {
            title: 'Corrección del detalle',
            groups: [
                {
                    type: 'selects',
                    items: [
                        {
                            id: 'correctionProductInput',
                            name: 'productId',
                            label: 'Producto correcto',
                            class: 'product-select',
                            col: '12'
                        }
                    ]
                },
                {
                    type: 'inputs',
                    items: [
                        {
                            id: 'correctionQuantityInput',
                            name: 'quantity',
                            type: 'number',
                            label: 'Cantidad correcta',
                            col: '6',
                            attrs: {
                                min: '0.01',
                                step: '0.01'
                            }
                        },
                        {
                            id: 'correctionCostPerUnitInput',
                            name: 'costPerUnitType',
                            type: 'number',
                            label: 'Costo por presentación correcto',
                            col: '6',
                            attrs: {
                                min: '0.01',
                                step: 'any'
                            }
                        }
                    ]
                },
                {
                    type: 'textarea',
                    input: {
                        id: 'correctionObservationsInput',
                        name: 'observations',
                        label: 'Observaciones'
                    }
                }
            ]
        },
        {
            title: 'Nuevos totales estimados',
            description: 'Se actualizan con la cantidad y el costo capturados antes de guardar la corrección.',
            groups: [
                {
                    type: 'html',
                    content: `
                        <div class="row g-2 correction-totals-summary" aria-live="polite">
                            ${renderTotalsSummaryItem({ label: 'Cantidad total', valueId: 'correctionTotalQuantity', value: '0.00' })}
                            ${renderTotalsSummaryItem({ label: 'Subtotal', valueId: 'correctionTotalNetPurchaseAmount', value: '$0.00' })}
                            ${renderTotalsSummaryItem({ label: 'Total con IVA', valueId: 'correctionTotalGrossPurchaseAmount', value: '$0.00' })}
                        </div>
                    `
                }
            ]
        }
    ],
    actions: [
        {
            id: 'cancelGoodsReceiptCorrectionBtn',
            class: 'btn btn-secondary',
            content: 'Cancelar',
            attrs: {
                'data-mdb-dismiss': 'modal',
                'data-bs-dismiss': 'modal'
            }
        },
        {
            id: 'confirmGoodsReceiptCorrectionBtn',
            type: 'submit',
            class: 'btn btn-primary',
            content: 'Corregir detalle'
        }
    ]
}; %>

<%- include('../../../shared/modal', {
    modalId: 'goodsReceiptCorrectionModal',
    modalTitle: 'Corregir detalle de compra',
    dialogClass: 'modal-lg modal-dialog-scrollable',
    form
}) %>
