<% const form = {
    id: 'goodsReceiptCorrectionForm',
    notice: {
        class: 'alert alert-warning mb-0',
        content: 'Esta acción corrige únicamente el detalle seleccionado. Genera ajustes compensatorios de inventario y costo; no se registrará como devolución al proveedor.'
    },
    sections: [
        {
            title: 'Corrección del detalle',
            groups: [
                {
                    type: 'selects',
                    items: [
                        {
                            id: 'correctionProductInput',
                            name: 'productId',
                            label: 'Producto correcto',
                            class: 'product-select',
                            col: '12'
                        }
                    ]
                },
                {
                    type: 'inputs',
                    items: [
                        {
                            id: 'correctionQuantityInput',
                            name: 'quantity',
                            type: 'number',
                            label: 'Stock correcto',
                            col: '6',
                            attrs: {
                                min: '0.01',
                                step: '0.01'
                            }
                        },
                        {
                            id: 'correctionCostPerUnitInput',
                            name: 'costPerUnitType',
                            type: 'number',
                            label: 'Costo por presentación correcto',
                            col: '6',
                            attrs: {
                                min: '0.01',
                                step: 'any'
                            }
                        }
                    ]
                },
                {
                    type: 'selects',
                    items: [
                        {
                            id: 'correctionReasonInput',
                            name: 'reasonId',
                            label: 'Razón de corrección',
                            class: '',
                            col: '12'
                        }
                    ]
                },
                {
                    type: 'textarea',
                    input: {
                        id: 'correctionObservationsInput',
                        name: 'observations',
                        label: 'Observaciones'
                    }
                }
            ]
        },
        {
            title: 'Totales estimados del detalle',
            description: 'Se actualizará solo este detalle y se recalcularán los totales de la compra. Inventario conservará la trazabilidad con ajustes de salida y entrada.',
            groups: [
                {
                    type: 'inputs',
                    items: [
                        {
                            id: 'correctionCurrentTotalInput',
                            name: 'currentTotal',
                            type: 'text',
                            label: 'Total actual',
                            col: '4',
                            attrs: {
                                disabled: '',
                                tabindex: '-1'
                            }
                        },
                        {
                            id: 'correctionCorrectedTotalInput',
                            name: 'correctedTotal',
                            type: 'text',
                            label: 'Total corregido',
                            col: '4',
                            attrs: {
                                disabled: '',
                                tabindex: '-1'
                            }
                        },
                        {
                            id: 'correctionTotalDifferenceInput',
                            name: 'totalDifference',
                            type: 'text',
                            label: 'Diferencia',
                            col: '4',
                            attrs: {
                                disabled: '',
                                tabindex: '-1'
                            }
                        }
                    ]
                },
                {
                    type: 'html',
                    content: `
                        <div class="alert alert-info mb-0">
                            Estos valores son solo de referencia para confirmar la corrección antes de guardarla.
                        </div>
                    `
                }
            ]
        }
    ],
    actions: [
        {
            id: 'cancelGoodsReceiptCorrectionBtn',
            class: 'btn btn-secondary',
            content: 'Cancelar',
            attrs: {
                'data-mdb-dismiss': 'modal',
                'data-bs-dismiss': 'modal'
            }
        },
        {
            id: 'confirmGoodsReceiptCorrectionBtn',
            type: 'submit',
            class: 'btn btn-primary',
            content: 'Corregir detalle'
        }
    ]
}; %>

<%- include('../../../shared/modal', {
    modalId: 'goodsReceiptCorrectionModal',
    modalTitle: 'Corregir detalle de compra',
    dialogClass: 'modal-lg modal-dialog-scrollable',
    form
}) %>
