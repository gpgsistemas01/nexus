            value: '0.00',
            rawValue: 0
        },
        {
            id: 'correctionTotalNetPurchaseAmount',
            label: 'Subtotal',
            value: '$0.00',
            rawValue: 0
        },
        {
            id: 'correctionTotalGrossPurchaseAmount',
            label: 'Total con IVA',
            value: '$0.00',
            rawValue: 0
        }
    ]
};

const form = {
