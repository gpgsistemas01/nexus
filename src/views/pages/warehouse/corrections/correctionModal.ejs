    sections: [
        {
            title: 'Corrección del detalle',
            groups: [
                {
                    type: 'inputs',
                    items: [
                        {
                            id: 'correctionQuantityInput',
                            name: 'quantity',
                            type: 'number',
                            label: 'Cantidad correcta',
                            col: '6',
                            attrs: {
                                min: '0.01',
                                step: '0.01'
                            }
                        },
                        {
                            id: 'correctionCostPerUnitInput',
                            name: 'costPerUnitType',
                            type: 'number',
                            label: 'Costo por presentación correcto',
                            col: '6',
                            attrs: {
                                min: '0.01',
                                step: 'any'
                            }
                        }
                    ]

                },
                {
                    type: 'html',
                    content: `
                        <div class="col-12">
                            <label class="form-label" for="correctionReasonNameInput">Razón del ajuste</label>
                            <select id="correctionReasonNameInput" name="reasonName" class="form-select w-100">
                                <option value="Corrección de compra">Corrección de compra</option>
                                <option value="Devolución de compra">Devolución de compra</option>
                            </select>
                            <div data-error-for="reasonName" class="invalid-feedback d-none"></div>
                            <div class="form-text">Use devolución cuando la disminución corresponde a material regresado al proveedor; use corrección cuando se está corrigiendo el registro de la compra.</div>
                        </div>
                    `
                }
            ]
        },
        {
